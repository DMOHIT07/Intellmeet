# Port number the backend server listens on
PORT=5000

# MongoDB Connection string
# For Local Database (Default):
MONGO_URI=mongodb://localhost:27017/intellmeet

# For Cloud Database (MongoDB Atlas):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxxx.mongodb.net/intellmeet?retryWrites=true&w=majority

# JSON Web Token Secret Key (change this to a strong random string in production)
JWT_SECRET=your_very_secret_key_here

# Server Environment mode (development / production)
NODE_ENV=development

# OpenAI API Key — used for AI meeting summary & action item extraction
# Leave empty (or remove this line) to use the built-in mock summary generator instead
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google OAuth 2.0 Client ID for Google Sign-in authentication
# Create one at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
